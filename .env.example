# ─────────────────────────────────────────────────────────────────────────────
# Staffroom Intel — environment variables
# Copy to .env.local (app) and/or Railway (worker). All Supabase vars are
# OPTIONAL: when absent the app runs on the in-memory TSV dataset (dev/demo).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (REQUIRED for production / persistent features)
# Project URL + service-role key (bypasses RLS — server/worker only, never
# expose to the browser). Find under Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Anon publishable key for browser-side reads (auth + public tables).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Reddit (OPTIONAL) ─────────────────────────────────────────────────────────
# The app works without these: client.ts falls back to the public RedReader
# installed_client flow (no developer key needed) for live gap-filling.
# Override only to use your own credentials / subreddits.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_SUBREDDITS=InternationalTeachers,InternationalSchools,TEFL

# ── Embeddings / semantic clustering (OPTIONAL) ───────────────────────────────
# Recommended: Google Gemini Embedding via its free developer tier. It emits
# 1536 dimensions to match Supabase pgvector. Pinecone Inference is also
# supported, but keep Supabase as the vector store rather than duplicating data.
EMBEDDINGS_PROVIDER=google
GOOGLE_AI_API_KEY=
# Alternative provider key:
PINECONE_API_KEY=
# Legacy OpenAI-compatible key:
EMBEDDINGS_API_KEY=
# Optional overrides. Defaults depend on EMBEDDINGS_PROVIDER:
# google=gemini-embedding-001, pinecone=llama-text-embed-v2,
# openai=text-embedding-3-small.
EMBEDDINGS_BASE_URL=
EMBEDDINGS_MODEL=

# ── Evidence brief agent (OPTIONAL) ───────────────────────────────────────────
# Runs only when a school's evidence changes, never on every page view.
# GOOGLE_AI_API_KEY is reused when AI_AGENT_API_KEY is empty.
AI_AGENT_API_KEY=
AI_AGENT_MODEL=gemini-3.1-flash-lite
AI_AGENT_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── Sentiment freshness (OPTIONAL) ────────────────────────────────────────────
# Hours before a school's cached corpus is considered stale and re-fetched live.
# Lower = fresher but more Reddit API calls; higher = cheaper but less current.
SENTIMENT_FRESHNESS_HOURS=6

# ── Worker (Railway) ──────────────────────────────────────────────────────────
WORKER_POLL_MS=5000
# Scheduled low-cost mode: cap jobs processed by `bun worker:once`.
WORKER_MAX_JOBS=25
